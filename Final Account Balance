SELECT
  account_id,
  Deposit - Withdrawal AS final_balance
FROM (
SELECT 
  account_id,
  SUM(CASE 
    WHEN transaction_type = 'Deposit' THEN amount
  END) AS Deposit,
  SUM(CASE 
    WHEN transaction_type = 'Withdrawal' THEN amount
  END) AS Withdrawal
FROM transactions
GROUP BY account_id) AS t1;
