WITH card_launch_date_cte AS (
  SELECT 
    card_name,
    issue_month,
    issue_year,
    issued_amount,
    ROW_NUMBER() OVER(PARTITION BY card_name ORDER BY issue_year, issue_month) AS card_launch_date_rank
  FROM monthly_cards_issued
)
SELECT
  card_name,
  issued_amount
FROM card_launch_date_cte
WHERE card_launch_date_rank = 1
ORDER BY issued_amount DESC;
